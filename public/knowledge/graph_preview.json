      "name": "第7章 区域性地基"
    },
    {
      "id": "concept:foundation-soil",
      "label": "Concept",
      "name": "地基",
      "definition": "直接承受建筑物、构筑物荷载影响的地层。"
    },
    {
      "id": "concept:foundation",
      "label": "Concept",
      "name": "基础",
      "definition": "将上部结构承受的各种荷载传递到地基上的结构。"
    },
    {
      "id": "concept:shallow",
      "label": "Concept",
      "name": "浅基础",
      "definition": "设计计算时不考虑利用基础侧面土体抗力抵抗荷载作用的基础。"
    },
    {
      "id": "concept:deep",
      "label": "Concept",
      "name": "深基础",
      "definition": "常通过桩、沉井、地下连续墙等把荷载传递到深部土层。"
    },
    {
      "id": "concept:pile",
      "label": "Concept",
      "name": "桩基础",
      "definition": "由桩和承台组成，将荷载传递至较深持力层或通过桩侧土共同承担。"
    },
    {
      "id": "concept:shaft-resistance",
      "label": "Concept",
      "name": "桩侧阻力",
      "definition": "桩身与周围土体相对位移时，桩侧土对桩身产生的摩擦阻力。"
    },
    {
      "id": "concept:end-resistance",
      "label": "Concept",
      "name": "桩端阻力",
      "definition": "桩端持力层受压变形时对桩端产生的竖向抗力。"
    },
    {
      "id": "concept:bearing",
      "label": "Concept",
      "name": "承载力",
      "definition": "地基或基础抵抗荷载并保持稳定的能力。"
    },
    {
      "id": "concept:settlement",
      "label": "Concept",
      "name": "沉降计算",
      "definition": "分析荷载作用下地基压缩变形及建筑物沉降的计算过程。"
    },
    {
      "id": "concept:pit",
      "label": "Concept",
      "name": "基坑工程",
      "definition": "围绕基坑开挖、支护、降水和环境影响控制的工程活动。"
    },
    {
      "id": "concept:treatment",
      "label": "Concept",
      "name": "地基处理",
      "definition": "通过换填、加固、排水固结等方法改善地基工程性质。"
    },
    {
      "id": "concept:regional",
      "label": "Concept",
      "name": "区域性地基",
      "definition": "湿陷性黄土、膨胀土、盐渍土、冻土等具有地区特征的地基。"
    }
  ],
