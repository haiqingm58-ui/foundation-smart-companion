FOUNDATION_SECRET_KEY=replace-with-a-long-random-secret
FOUNDATION_DATA_DIR=/var/lib/foundation-smart-companion
FOUNDATION_DATABASE_URL=postgresql+psycopg://foundation_app:change-me@127.0.0.1/foundation_smart_companion
FOUNDATION_UPLOAD_DIR=/var/lib/foundation-smart-companion/uploads
FOUNDATION_SESSION_TTL_SECONDS=43200
FOUNDATION_CAPTCHA_TTL_SECONDS=120
FOUNDATION_COOKIE_PATH=/foundation-smart-companion
FOUNDATION_COOKIE_SECURE=false

# Optional: OpenAI-compatible chat completions endpoint.
# If these are not set, /api/qa still returns a server-side RAG answer with citations.
FOUNDATION_LLM_API_URL=
FOUNDATION_LLM_API_KEY=
FOUNDATION_LLM_MODEL=gpt-4o-mini
