{
  "name": "foundation-smart-companion",
  "version": "0.0.0",
  "private": true,
  "type": "module",
  "scripts": {
    "dev": "vite --host 127.0.0.1",
    "build": "vite build",
    "postbuild": "node scripts/prerender.mjs",
    "preview": "vite preview --host 127.0.0.1",
    "test": "vitest run",
    "test:watch": "vitest",
    "test:backend": "server/.venv/bin/pytest server/tests -q",
    "test:e2e": "playwright test",
    "test:deploy": "bash scripts/tests/deploy-utils.test.sh",
    "check": "npm run test && npm run test:backend && npm run test:deploy && npm run build",
    "deploy:jdcloud": "bash scripts/deploy-platform-jdcloud.sh",
    "perf:lhci": "npm exec --yes --package=@lhci/cli@0.15.1 -- lhci autorun --config=./lighthouserc.cjs"
  },
  "dependencies": {
    "@vitejs/plugin-react": "5.0.4",
    "lucide-react": "^1.17.0",
    "react": "19.2.0",
    "react-dom": "19.2.0",
    "react-router-dom": "^7.18.1",
    "vite": "6.4.3"
  },
  "devDependencies": {
    "@playwright/test": "^1.61.1",
    "@testing-library/jest-dom": "^6.6.3",
    "@testing-library/react": "^16.3.0",
    "eslint": "^9.31.0",
    "jsdom": "^26.1.0",
    "vitest": "^4.1.9"
  }
}
